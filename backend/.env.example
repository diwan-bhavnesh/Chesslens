# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev — file created automatically on first run)
DATABASE_URL=sqlite:///./chesslens.db
# For Postgres: DATABASE_URL=postgresql://user:password@localhost:5432/chesslens

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required for playing style + coaching recommendations.
# Get a key at: https://console.anthropic.com
# Optional — the app works without it. Profile builds but claude_profile will be null.
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Only needed for "Sign in with Google". Email/password auth works without this.
# To set up: https://console.cloud.google.com → APIs & Services → Credentials
#   1. Create an OAuth 2.0 Client ID (type: Web application)
#   2. Add authorised redirect URI: http://localhost:8000/auth/google/callback
# Leave blank to skip Google OAuth — email/password login will still work.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Stockfish ─────────────────────────────────────────────────────────────────
# Path to the Stockfish binary (NOT the Python package — the actual engine executable).
# macOS (Homebrew):  /opt/homebrew/bin/stockfish  or  /usr/local/bin/stockfish
# Linux:             /usr/bin/stockfish  (after: apt install stockfish)
# Windows:           C:\path\to\stockfish.exe
STOCKFISH_PATH=/usr/local/bin/stockfish
STOCKFISH_DEPTH=18          # per-game review depth
STOCKFISH_BULK_DEPTH=1      # Layer 2 bulk profile depth (fast; see README for caveat)

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
